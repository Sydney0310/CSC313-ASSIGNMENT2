<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A237E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:paddingEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="List a Textbook"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Book Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#1A237E"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖  Book Details"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Book Title *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Author *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etModuleCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Module Code (e.g. CSC313) *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etEdition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Edition (e.g. 3rd Edition)"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etCopies"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="No. of Copies *"
                    android:inputType="number"
                    android:background="@android:color/white"
                    android:padding="14dp"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Price (R) *"
                    android:inputType="numberDecimal"
                    android:background="@android:color/white"
                    android:padding="14dp"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Seller Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#2E7D32"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Seller Details"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etSellerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Your Full Name *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etContactNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact Number *"
                android:inputType="phone"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:textSize="14sp"/>

            <!-- Banking Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="#E65100"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏦  Banking Details"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etBankName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Bank Name (e.g. FNB, Capitec) *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Account Number *"
                android:inputType="number"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etAccountHolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Account Holder Name *"
                android:background="@android:color/white"
                android:padding="14dp"
                android:layout_marginBottom="24dp"
                android:textSize="14sp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnSubmit"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submit Listing"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>